{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/agent-run",
      "schedule": "0 */4 * * *"
    }
  ],
  "functions": {
    "api/agent-run.ts": {
      "maxDuration": 120,
      "memory": 1024
    }
  }
}
